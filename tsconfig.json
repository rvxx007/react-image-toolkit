{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react-jsx",

    "strict": true,

    "declaration": true,
    "declarationMap": true,

    "moduleResolution": "Bundler",

    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "skipLibCheck": true
  },
  "include": [
    "src",
    "src/global.d.ts"
  ]
}